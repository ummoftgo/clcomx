{
  "name": "clcomx",
  "private": true,
  "version": "0.3.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "check:frontend": "svelte-check --tsconfig ./tsconfig.json && vite build",
    "check:rust": "cargo check --manifest-path src-tauri/Cargo.toml",
    "check": "npm run check:frontend && npm run check:rust",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "vitest run --config ./vitest.e2e.config.ts",
    "test:e2e:smoke": "node ./scripts/run-e2e-project.mjs smoke",
    "test:e2e:settings": "node ./scripts/run-e2e-project.mjs settings",
    "test:e2e:windows-tabs": "node ./scripts/run-e2e-project.mjs windows-tabs",
    "test:e2e:workspace-restore": "node ./scripts/run-e2e-project.mjs workspace-restore",
    "test:e2e:image-paste": "node ./scripts/run-e2e-project.mjs image-paste",
    "test:e2e:terminal-input": "node ./scripts/run-e2e-project.mjs terminal-input",
    "test:e2e:terminal-links": "node ./scripts/run-e2e-project.mjs terminal-links",
    "test:e2e:terminal-aux": "node ./scripts/run-e2e-project.mjs terminal-aux",
    "test:e2e:sync": "bash scripts/sync-e2e-mirror.sh",
    "test:e2e:windows": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File .\\scripts\\e2e-smoke-windows.ps1",
    "test:e2e:wsl": "bash scripts/e2e-smoke-windows.sh",
    "test:rust": "cargo test --manifest-path src-tauri/Cargo.toml",
    "verify": "npm run test && npm run test:rust && npm run check",
    "tauri": "tauri"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.10.1",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-serialize": "^0.14.0",
    "@xterm/addon-unicode11": "^0.9.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/addon-webgl": "^0.19.0",
    "@xterm/xterm": "^6.0.0",
    "svelte-i18n": "^4.0.1"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@tauri-apps/cli": "^2.10.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/svelte": "^5.3.1",
    "@testing-library/user-event": "^14.6.1",
    "jsdom": "^29.0.1",
    "selenium-webdriver": "^4.41.0",
    "svelte": "^5.55.0",
    "svelte-check": "^4.4.5",
    "typescript": "^6.0.2",
    "vite": "^8.0.3",
    "vitest": "^4.1.2"
  }
}
